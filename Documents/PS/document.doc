    <m:r><m:t>180</m:t></m:r><m:r><m:rPr><m:sty m:val="p"></m:sty></m:rPr><m:t><span style="font-style:normal;">&#xB0;</span></m:t></m:r>
  </m:oMath>
</m:oMathPara></span></p>
</td></tr><tr><td valign="top" align="left"><p align="left" style="margin-left:0pt;text-align:left;" class="MsoNormal"><b>West Bounding Longitude:</b></p></td><td valign="top"><p class="MsoNormal"><a name="_9c29ce52-d40f-682a-8f9d-4d9af1d823a4" id="_9c29ce52-d40f-682a-8f9d-4d9af1d823a4"></a><span class="stem"><m:oMathPara>
  <m:oMathParaPr><m:jc m:val="left"/></m:oMathParaPr><m:oMath>
    <m:r><m:t>&#x2212;</m:t></m:r><m:r><m:t>180</m:t></m:r><m:r><m:rPr><m:sty m:val="p"></m:sty></m:rPr><m:t><span style="font-style:normal;">&#xB0;</span></m:t></m:r>
  </m:oMath>
</m:oMathPara></span></p>
</td></tr><tr><td valign="top" align="left"><p align="left" style="margin-left:0pt;text-align:left;" class="MsoNormal"><b>North Bounding Latitude:</b></p></td><td valign="top"><p class="MsoNormal"><a name="_9357f21d-535a-d6a3-6d55-477e889398e2" id="_9357f21d-535a-d6a3-6d55-477e889398e2"></a><span class="stem"><m:oMathPara>
  <m:oMathParaPr><m:jc m:val="left"/></m:oMathParaPr><m:oMath>
